# n8n on AWS EKS - Configuration Template
# Copy this file to .env and customize for your environment
# DO NOT commit .env to version control

# ============================================================================
# AWS Configuration
# ============================================================================

# AWS Region where resources will be created
AWS_REGION=ap-southeast-2

# AWS CLI profile to use (default uses your default profile)
AWS_PROFILE=default

# ECR Account ID for container images
# Leave empty to auto-detect from current AWS account
# Set to specific account if using shared ECR registry
ECR_ACCOUNT=

# ============================================================================
# Container Images
# ============================================================================

# Use public Docker Hub images instead of ECR
# Set to true if deploying without ECR access
USE_PUBLIC_IMAGES=false

# Container image versions
N8N_IMAGE_TAG=2.11.0
POSTGRES_IMAGE_TAG=16.6

# ============================================================================
# Network Configuration
# ============================================================================

# Corporate proxy URL (leave empty if no proxy needed)
# Example: http://proxy.example.com:8080
PROXY_URL=

# Corporate network CIDR for ALB security group
# This allows access from your corporate network
CORPORATE_CIDR=10.0.0.0/8

# ============================================================================
# Cluster Configuration
# ============================================================================

# EKS cluster name
CLUSTER_NAME=n8n-cluster

# Environment type: dev, test, or prod
# This affects instance types, backup retention, and costs
ENVIRONMENT=dev

# Kubernetes namespace
NAMESPACE=n8n

# ============================================================================
# Domain & DNS Configuration (Required for ALB with HTTPS)
# ============================================================================

# Domain name for n8n (e.g., n8n.example.com)
DOMAIN=

# Route53 Hosted Zone ID
HOSTED_ZONE_ID=

# ============================================================================
# VPC Configuration (Required)
# ============================================================================

# VPC ID where EKS cluster will be deployed
VPC_ID=

# Private subnet IDs (comma-separated)
# Example: subnet-abc123,subnet-def456,subnet-ghi789
PRIVATE_SUBNETS=

# ============================================================================
# RDS Configuration
# ============================================================================

# RDS instance class (varies by environment)
# dev: db.t3.micro, test: db.t3.small, prod: db.t3.medium
RDS_INSTANCE_CLASS=

# Enable Multi-AZ for RDS (recommended for production)
RDS_MULTI_AZ=false

# Backup retention period in days
# dev: 0, test: 7, prod: 30
RDS_BACKUP_RETENTION=7

# ============================================================================
# n8n Owner Credentials (Optional)
# ============================================================================

# Default owner account email
# Password will be auto-generated and stored in AWS SSM/Secrets Manager
OWNER_EMAIL=admin@example.com
OWNER_FIRST_NAME=Admin
OWNER_LAST_NAME=User

# ============================================================================
# Advanced Configuration (Optional)
# ============================================================================

# Enable horizontal pod autoscaling
ENABLE_HPA=false

# Minimum and maximum replicas for autoscaling
MIN_REPLICAS=1
MAX_REPLICAS=3

# EFS lifecycle policy (days until Infrequent Access)
# dev/test: 7, prod: 30
EFS_LIFECYCLE_DAYS=7
