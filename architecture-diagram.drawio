        <mxCell id="n8n-pod" value="&lt;b&gt;n8n Pod&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Image: ECR 993676232205/n8n:2.11.0&lt;br&gt;• HTTP_PROXY: 10.122.108.59:8080&lt;br&gt;• Port: 5678&lt;br&gt;&lt;br&gt;&lt;b&gt;Volumes:&lt;br&gt;&lt;/b&gt;&lt;br&gt;• /home/node/.n8n (EFS PVC)&lt;br&gt;  - Custom nodes&lt;br&gt;  - Config files&lt;br&gt;  - SSL certs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="120" y="474" width="400" height="220" as="geometry" />
        </mxCell>
        <mxCell id="rds" value="&lt;b&gt;Amazon RDS PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Engine: PostgreSQL 16.6&lt;br&gt;• Instance: db.t3.micro (dev) / db.t3.medium (prod)&lt;br&gt;• Multi-AZ: dev/test - No | prod - optional&lt;br&gt;• SSL: Required&lt;br&gt;• Storage: Workflows, credentials, execution history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="620" y="394" width="470" height="140" as="geometry" />
        </mxCell>
        <mxCell id="efs" value="&lt;b&gt;Amazon EFS (Elastic File System)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Storage Class: EFS-SC&lt;br&gt;• Access Mode: ReadWriteMany (HA-ready)&lt;br&gt;• Lifecycle: 7 days (dev) / 30 days (prod) → IA&lt;br&gt;• Encrypted: Yes&lt;br&gt;• Mount Targets: All subnets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="620" y="554" width="470" height="140" as="geometry" />
        </mxCell>
        <mxCell id="route53" value="&lt;b&gt;Route53 Private Hosted Zone&lt;/b&gt;&lt;br&gt;&lt;br&gt;• CNAME: n8n-cluster....twecloud.com&lt;br&gt;• Target: ALB DNS name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" parent="1" vertex="1">
          <mxGeometry x="747" y="254" width="340" height="100" as="geometry" />
