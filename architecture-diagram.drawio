          <mxGeometry x="40" y="200" width="1080" height="560" as="geometry" />
        </mxCell>
        
        <!-- ALB -->
        <mxCell id="alb" value="Application Load Balancer&#xa;&#xa;• Internal (no public IP)&#xa;• HTTPS:443 → HTTP:NodePort&#xa;• ACM Certificate&#xa;• SG: 10.0.0.0/8:443 + VPC CIDR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="280" height="100" as="geometry" />
        </mxCell>
        
        <!-- EKS Cluster -->
        <mxCell id="eks" value="Amazon EKS Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;verticalAlign=top;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="480" height="340" as="geometry" />
        </mxCell>
        
        <!-- n8n Namespace -->
        <mxCell id="namespace" value="Namespace: n8n" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;verticalAlign=top;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="420" width="440" height="280" as="geometry" />
        </mxCell>
        
        <!-- n8n Pod -->
        <mxCell id="n8n-pod" value="n8n Pod&#xa;&#xa;• Image: ECR 993676232205/n8n:2.11.0&#xa;• HTTP_PROXY: 10.122.108.59:8080&#xa;• Port: 5678&#xa;&#xa;Volumes:&#xa;• /home/node/.n8n (EFS PVC)&#xa;  - Custom nodes&#xa;  - Config files&#xa;  - SSL certs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="120" y="460" width="400" height="220" as="geometry" />
        </mxCell>
        
        <!-- RDS -->
        <mxCell id="rds" value="Amazon RDS PostgreSQL&#xa;&#xa;• Engine: PostgreSQL 16.6&#xa;• Instance: db.t3.micro (dev) / db.t3.medium (prod)&#xa;• Multi-AZ: No (dev/test) / Yes (prod)&#xa;• SSL: Required&#xa;• Storage: Workflows, credentials, execution history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="380" width="480" height="140" as="geometry" />
        </mxCell>
        
        <!-- EFS -->
        <mxCell id="efs" value="Amazon EFS (Elastic File System)&#xa;&#xa;• Storage Class: EFS-SC&#xa;• Access Mode: ReadWriteMany (HA-ready)&#xa;• Lifecycle: 7 days (dev) / 30 days (prod) → IA&#xa;• Cost: ~$0.45/month per environment&#xa;• Encrypted: Yes&#xa;• Mount Targets: All subnets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="620" y="540" width="480" height="140" as="geometry" />
        </mxCell>
        
        <!-- Route53 -->
        <mxCell id="route53" value="Route53 Private Hosted Zone&#xa;&#xa;• CNAME: n8n-cluster.001.ent-apps-npe-apse2...twecloud.com&#xa;• Target: ALB DNS name" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="240" width="340" height="100" as="geometry" />
        </mxCell>
        
        <!-- Internet/Proxy -->
        <mxCell id="internet" value="Internet (via Proxy)&#xa;&#xa;Corporate Proxy: 10.122.108.59:8080&#xa;• n8n community registration&#xa;• Workflow templates&#xa;• Updates and notifications" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="800" width="360" height="120" as="geometry" />
        </mxCell>
        
        <!-- Cost Breakdown -->
        <mxCell id="costs" value="Cost Breakdown (ap-southeast-2)&#xa;&#xa;Dev Environment (~$113/month):&#xa;• EKS Control Plane: $73.00&#xa;• EC2 (1x t3.small spot): $8.76&#xa;• RDS (db.t3.micro): $15.00&#xa;• ALB: $16.43&#xa;• EFS (10GB with IA): $0.45&#xa;&#xa;Production Environment (~$385/month):&#xa;• EKS Control Plane: $73.00&#xa;• EC2 (3x t3.medium): $175.00&#xa;• RDS (db.t3.medium Multi-AZ): $120.00&#xa;• ALB: $16.43&#xa;• EFS (20GB with IA): $0.90" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="800" width="680" height="240" as="geometry" />
        </mxCell>
        
