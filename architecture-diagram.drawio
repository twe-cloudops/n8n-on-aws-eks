        <mxCell id="alb" value="&lt;b&gt;Application Load Balancer&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Internal (no public IP)&lt;br&gt;• HTTPS:443 → HTTP:NodePort&lt;br&gt;• ACM Certificate&lt;br&gt;• SG: 10.0.0.0/8:443 + VPC CIDR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" parent="1" vertex="1">
